<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:gravity="end"
    android:layout_marginBottom="8dp" android:paddingStart="48dp">

    <TextView android:id="@+id/bubbleSender" android:text="You"
        android:textSize="11sp" android:textColor="#6C757D"
        android:layout_marginEnd="4dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/bubbleText" android:text=""
        android:textSize="15sp" android:textColor="#FFFFFF"
        android:background="@drawable/bubble_mine_bg"
        android:padding="12dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>