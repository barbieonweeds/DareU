    android:orientation="vertical" android:gravity="start"
    android:layout_marginBottom="8dp" android:paddingEnd="48dp">

    <TextView android:id="@+id/bubbleSender" android:text="Opponent"
        android:textSize="11sp" android:textColor="#6C757D"
        android:layout_marginStart="4dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/bubbleText" android:text=""
        android:textSize="15sp" android:textColor="#1A1A2E"
        android:background="@drawable/bubble_theirs_bg"
        android:padding="12dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
</LinearLayout>