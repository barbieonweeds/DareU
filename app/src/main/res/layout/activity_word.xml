<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center"
    android:background="#F8F9FA" android:padding="32dp">

    <TextView android:id="@+id/versusText" android:text="You vs Opponent"
        android:textSize="20sp" android:textStyle="bold" android:gravity="center"
        android:textColor="#1A1A2E" android:layout_marginBottom="8dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Pick your secret trap word"
        android:textSize="14sp" android:textColor="#6C757D" android:gravity="center"
        android:layout_marginBottom="8dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:text="Your opponent must say this word for you to win!"
        android:textSize="12sp" android:textColor="#ADB5BD" android:gravity="center"
        android:layout_marginBottom="32dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

    <androidx.cardview.widget.CardView
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="24dp" app:cardCornerRadius="16dp" app:cardElevation="4dp">
        <EditText android:id="@+id/wordInput" android:hint="Enter one word..."
            android:inputType="text" android:textSize="22sp" android:gravity="center"
            android:padding="20dp" android:background="@null"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </androidx.cardview.widget.CardView>

    <Button android:id="@+id/confirmWordBtn" android:text="Set Trap Word 🎯"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="#4361EE" android:textColor="#FFFFFF" android:textSize="16sp"
        style="@style/Widget.MaterialComponents.Button"/>
</LinearLayout>